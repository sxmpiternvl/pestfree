# ─────────────────────────────────────────────────────────────────────
# API (apps/api/.env)
# ─────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/pestfree"

# API port (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins
# Local dev: http://localhost:3000   Prod: https://pest-free.uz
WEB_ORIGIN=http://localhost:3000

# Telegram credentials — API uses these to notify the owner about new leads.
# Get BOT_TOKEN from @BotFather, OWNER_CHAT_ID from @userinfobot.
BOT_TOKEN=
OWNER_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────
# Web (apps/web/.env.local)
# ─────────────────────────────────────────────────────────────────────

# Public API URL used by the browser to submit the lead form.
# Leave empty in dev to run the form in stub mode (no API call).
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────
# Telegram bot (apps/bot/.env)
# ─────────────────────────────────────────────────────────────────────

# Bot token from @BotFather (same value as API's BOT_TOKEN)
BOT_TOKEN=

# Bot username without @ (e.g. pestfree_bot)
BOT_USERNAME=

# Base URL of the NestJS API the bot submits leads to
API_BASE_URL=http://localhost:3001
