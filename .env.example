# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/pestfree"

# API port (default: 3001)
PORT=3001

# Web app: public API URL (used by the browser to call the NestJS API)
# Place this in apps/web/.env.local for local development
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Telegram bot (apps/bot) ─────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=

# Bot username without @ (e.g. pestfree_bot)
BOT_USERNAME=

# Owner's Telegram chat ID — receives a notification on every new lead
OWNER_CHAT_ID=

# Base URL of the NestJS API the bot submits leads to
API_BASE_URL=http://localhost:3001
